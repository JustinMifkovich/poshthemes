{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "white":     "#CED0D6",
    "bg":        "#1E1F22",
    "purple":    "#BA8EF7",
    "plum":      "#9A348E",
    "pink":      "#FF8AD1",
    "orange":    "#FFA763",
    "yellow":    "#DCDCAA",
    "teal":      "#56ADB7",
    "blue":      "#548AF7",
    "muted":     "#6F737A",
    "green":     "#7EC482"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "aws",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "foreground": "p:bg",
          "background": "p:blue",
          "template": " \ue7ad {{ if .Profile }}{{ .Profile }}{{ end }} ",
          "properties": {
            "display_profile": true,
            "display_region": false,
            "display_default_region": false,
            "display_account": false
          }
        },
        {
          "type": "text",
          "style": "powerline",
          "foreground": "p:bg",
          "background": "p:teal",
          "powerline_symbol": "\ue0b0",
          "template": "{{ if .Env.PNPPSHOST }} \uf8c5 {{ .Env.PNPPSHOST }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "foreground": "p:bg",
          "background": "p:teal",
          "powerline_symbol": "\ue0b0",
          "template": "{{ if .Env.PNPPSSITE }} \uf2dd {{ .Env.PNPPSSITE }}{{ end }}"
        },
        {
          "type": "text",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "p:bg",
          "background": "p:teal",
          "template": "{{ if or .Env.PNPPSSITE .Env.PNPPSHOST }}\u00A0{{ end }}"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:purple",
          "foreground": "p:bg",
          "powerline_symbol": "\ue0b4",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "p:purple",
          "foreground": "p:bg",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "{{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "p:pink",
          "foreground": "p:bg",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:orange",
          "foreground": "p:bg",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "branch_icon": "",
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " \u279c ({{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}) ",
          "type": "git"
        },
        {
          "background": "p:teal",
          "foreground": "p:bg",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "type": "node"
        },
        {
          "background": "p:yellow",
          "foreground": "p:bg",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \ue235 {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} ",
          "type": "python",
          "properties": {
            "always_enabled": true
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 3
}